{
	"name": "@local/pi-builder-skills",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"keywords": ["pi-package"],
	"description": "Code-grounded Agent Skills for building with Pi (pi-mono). See README in repo root.",
	"pi": {
		"skills": [
			"./pi-cli-workspace",
			"./pi-extension-authoring",
			"./pi-package-authoring",
			"./pi-ai-library",
			"./pi-agent-embedding",
			"./pi-web-ui",
			"./pi-rpc-sdk",
			"./pi-tui",
			"./pi-mom",
			"./pi-pods",
			"./pi-customization"
		]
	},
	"scripts": {
		"ci": "npm test && npm run grade-graded-examples && npm run verify-skills",
		"test": "node --test tests/*.test.mjs",
		"verify-skills": "node scripts/verify-all.mjs",
		"sync-evals": "node scripts/sync-evals-packs.mjs",
		"bump-corpus": "node scripts/bump-corpus.mjs",
		"extract-grade-assertions": "node scripts/extract-grade-assertions.mjs",
		"scaffold-graded-example": "node scripts/scaffold-graded-example.mjs",
		"grade-example": "node scripts/grade-assertions.mjs --response evals/graded-examples/cli-precedence-001/with_skill/response.md --assertions evals/graded-examples/cli-precedence-001/assertions.json --out evals/graded-examples/cli-precedence-001/with_skill/grading.json",
		"grade-example-rpc": "node scripts/grade-assertions.mjs --response evals/graded-examples/rpc-framing-001/with_skill/response.md --assertions evals/graded-examples/rpc-framing-001/assertions.json --out evals/graded-examples/rpc-framing-001/with_skill/grading.json",
		"grade-example-rpc-sdk": "node scripts/grade-assertions.mjs --response evals/graded-examples/rpc-sdk-choice-002/with_skill/response.md --assertions evals/graded-examples/rpc-sdk-choice-002/assertions.json --out evals/graded-examples/rpc-sdk-choice-002/with_skill/grading.json",
		"grade-graded-examples": "node scripts/grade-all-graded-examples.mjs"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
